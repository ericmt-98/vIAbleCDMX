# ViableCDMX Bot - Variables de Entorno
# Copia este archivo como .env y llena los valores

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# API Key de Anthropic Claude (para clasificacion de giros y respuestas IA)
ANTHROPIC_API_KEY=tu_api_key_aqui

# Webhook URL (opcional, solo para produccion)
# Si no se configura, el bot correra en modo polling (desarrollo)
# Ejemplo: https://tu-dominio.com
WEBHOOK_URL=

# Puerto para webhook (default: 8443)
PORT=8443
